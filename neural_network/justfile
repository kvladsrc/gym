set shell := ["bash", "-euo", "pipefail", "-c"]

model := "data/mnist-model.txt"

# Show all available commands
default:
    @just --list --list-submodules

# Download and unpack the MNIST dataset
download:
    ./download_mnist.sh

# Download and unpack the CIFAR-10 binary dataset
download-cifar10:
    bash ./download_cifar10.sh

# Train and evaluate a model on MNIST or CIFAR-10
train dataset="mnist":
    bazelisk run -c opt //neural_network:train -- \
        "{{dataset}}" \
        "$PWD/data" \
        "$PWD/data/{{dataset}}-model.txt"

# Start the drawing UI with the saved MNIST model
serve host="127.0.0.1" port="8000":
    test -f "$PWD/{{model}}" || { echo "Model not found. Run: just neural_network train" >&2; exit 1; }
    bazelisk build //neural_network:nn_predict
    python3 "$PWD/web_server.py" \
        --predictor "$PWD/../bazel-bin/neural_network/nn_predict" \
        --model "$PWD/{{model}}" \
        --page "$PWD/web/index.html" \
        --host "{{host}}" \
        --port "{{port}}"
