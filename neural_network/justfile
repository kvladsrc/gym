set shell := ["bash", "-euo", "pipefail", "-c"]

model := "data/mnist-model.txt"
cifar10_model := "data/cifar10-model.txt"

# Show all available commands
default:
    @just --list --list-submodules

# Download and unpack the MNIST dataset
download:
    ./download_mnist.sh

# Download and unpack the CIFAR-10 binary dataset
download-cifar10:
    bash ./download_cifar10.sh

# Train on 60,000 MNIST images and evaluate on the official 10,000 test images
train:
    bazelisk run //neural_network:nn -- \
        "$PWD/data/train-images-idx3-ubyte" \
        "$PWD/data/train-labels-idx1-ubyte" \
        "$PWD/data/t10k-images-idx3-ubyte" \
        "$PWD/data/t10k-labels-idx1-ubyte" \
        "$PWD/{{model}}"

# Train for three epochs on CIFAR-10 and evaluate on its official test batch
train-cifar10:
    bazelisk run -c opt //neural_network:cifar10_nn -- \
        "$PWD/data/cifar-10-batches-bin" \
        "$PWD/{{cifar10_model}}"

# Start the drawing UI with the saved MNIST model
serve host="127.0.0.1" port="8000":
    test -f "$PWD/{{model}}" || { echo "Model not found. Run: just neural_network train" >&2; exit 1; }
    bazelisk build //neural_network:nn_predict
    python3 "$PWD/web_server.py" \
        --predictor "$PWD/../bazel-bin/neural_network/nn_predict" \
        --model "$PWD/{{model}}" \
        --page "$PWD/web/index.html" \
        --host "{{host}}" \
        --port "{{port}}"
