# Common
build --http_timeout_scaling=3.0

# Buildbuddy cache
build --bes_backend=grpcs://bb-grpc.your.domain
build --bes_results_url=https://bb.your.domain/invocation/
build --remote_cache=grpcs://bb-grpc.your.domain
build --remote_max_connections=20
build --remote_timeout=10m

# Sanitizers
# Usage: bazel test //... --config=asan
build:asan --copt=-fsanitize=address
build:asan --linkopt=-fsanitize=address
build:asan --copt=-fno-omit-frame-pointer

# Usage: bazel test //... --config=ubsan
build:ubsan --copt=-fsanitize=undefined
build:ubsan --linkopt=-fsanitize=undefined
build:ubsan --action_env=UBSAN_OPTIONS=halt_on_error=1:print_stacktrace=1

# Usage: bazel test //... --config=tsan
build:tsan --copt=-fsanitize=thread
build:tsan --linkopt=-fsanitize=thread

# Pass LD_LIBRARY_PATH to runtime so dlopen can find libcuda.so.1 from nix
build --action_env=LD_LIBRARY_PATH
